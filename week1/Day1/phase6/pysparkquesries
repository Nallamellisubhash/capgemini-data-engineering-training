from pyspark.sql import SparkSession
from pyspark.sql.functions import *

# create spark session
spark = SparkSession.builder.getOrCreate()

# create customers dataset with some null values
customers_data = [
    (1, "John Doe", "john@example.com", "Hyderabad"),
    (2, "Alice ", "alice@example.com", "Chennai"),
    (3, None, "bob@example.com", "Bangalore"),
    (4, "David", None, "Mumbai"),
    (5, "Eva", "eva@example.com", "Hyderabad"),
    (6, "Frank", "frank@example.com", "Delhi"),
]

customers = spark.createDataFrame(customers_data, ["customer_id", "name", "email", "city"])

# create orders dataset with invalid and null values
orders_data = [
    (101, 1, "2024-01-01", 1000),
    (102, 2, "2024-01-02", 2000),
    (103, 3, "2024-01-03", -500),
    (104, 99, "2024-01-04", 1500),
    (105, 1, "2024-01-05", None),
    (106, 5, "2024-01-06", 3000),
    (107, 5, "2024-01-07", 3000),
]

orders = spark.createDataFrame(orders_data, ["order_id", "customer_id", "order_date", "amount"])

# convert string to date
orders = orders.withColumn("order_date", to_date(col("order_date")))

# remove null rows
customers=customers.dropna()
orders=orders.dropna()

# replace negative amount with 0
orders=orders.withColumn("amount",when(col("amount")<0,0).otherwise(col("amount")))

# remove duplicate customer records
orders = orders.dropDuplicates(["customer_id"])
orders.show()

# remove extra spaces in name
customers=customers.withColumn("name", trim(col("name")))
customers.show()

# display data
customers.show()
orders.show()

# find invalid customer_id using left_anti join
invalid_val=orders.join(customers,"customer_id","left_anti")
invalid_val.show() 

# calculate total spend and order count
agg_df = customers.join(orders, "customer_id", "inner") \
    .groupBy("customer_id", "name", "city") \
    .agg(
        sum("amount").alias("total_spend"),
        count("order_id").alias("order_count")
    )
agg_df.show()

from pyspark.sql.window import Window
from pyspark.sql.functions import dense_rank, col

# rank customers by total spend
window_spec = Window.orderBy(col("total_spend").desc())

ranked_df = agg_df.withColumn(
    "rank",
    dense_rank().over(window_spec)
)

ranked_df.show()

# find top 3 customers per city
window_spec1=Window.partitionBy("city").orderBy(col("total_spend").desc())
top3=agg_df.withColumn("top3 customer",rank().over(window_spec1)).filter(col("top3 customer")<=3)
top3.show()

# join datasets
df=orders.join(customers,"customer_id")
df.show()

# monthly sales calculation
monthly_sales=df.withColumn("month",month(col("order_date"))).groupBy("month").agg(sum("amount"))
monthly_sales.show()

# calculate date difference
date_diff=df.withColumn("diff",datediff(current_date(),col("order_date")))
date_diff.show() 

# monthly sales aggregation
monthly = orders.withColumn("month", month(col("order_date"))) \
    .groupBy("month") \
    .agg(sum("amount").alias("total_sales"))

# window for previous month
window_spec = Window.orderBy("month")

# calculate previous month sales and growth
trend = monthly.withColumn(
    "prev_month_sales",
    lag("total_sales", 1).over(window_spec)
).withColumn(
    "growth",
    col("total_sales") - col("prev_month_sales")
)

trend.show()
