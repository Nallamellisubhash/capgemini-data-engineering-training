sales_clean = sales.withColumn("total_amount", col("total_amount").cast("double"))

df = customers.join(sales_clean, "customer_id")

city_revenue = df.groupBy("city") \
    .agg(sum("total_amount").alias("total_revenue"))

city_revenue.show()
